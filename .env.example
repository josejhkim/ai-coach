# retrieve Gemini API keys from Upstash Redis instance
# to automatically rotate between multiple keys on quota/rate-limit errors
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

GEMINI_KEYS_REDIS_LIST=gemini_api_keys

PAT_CONSOLE_PATH=/absolute/path/to/PAT.Console.exe
PAT_USE_MONO=
MONO_PATH=mono
PAT_TIMEOUT_S=120
RUNS_DIR=runs
